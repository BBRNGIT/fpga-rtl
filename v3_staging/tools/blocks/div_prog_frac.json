      "name": "CLK",
      "dir": "in",
      "kind": "clock"
    },
    {
      "name": "RST",
      "dir": "in"
    },
    {
      "name": "O",
      "dir": "out",
      "kind": "clock"
    },
    {
      "name": "FRAC_CARRY",
      "dir": "out"
    }
  ],
