#!/usr/bin/env python3
"""gen_{{ spec.device }}_net.py — EMITTER: writes {{ spec.device }}.net.json.

This python file is the real deliverable (DESIGN_GUIDE step 3): it emits the
netlist describing {{ spec.device }} as addressed register nodes wired as cells
— branchless. gennet.py then GENERATES the device C from this netlist; the
device tick is never hand-written.

{{ spec.comment }}

Auto-generated by partslist-to-emitter.py from {{ spec.device | upper }}_PARTS_LIST.md
"""
import json

NET = {
    "device": "{{ spec.device }}",
    "window_base": "{{ spec.window_base }}",
    "kind": "{{ spec.kind }}",
    "comment": (
        "{{ spec.comment }} "
        "(auto-generated from PARTS_LIST)"
    ),

    # --- input lanes (driven from outside the netlist: set by the starter). ---
{%- if spec.config_nodes %}
    "config_nodes": [
{%- for node in spec.config_nodes %}
        {"name": "{{ node.name }}", "type": "{{ node.type }}",
         "comment": "{{ node.comment | replace('"', '\\"') }}"},
{%- endfor %}
    ],
{%- else %}
    "config_nodes": [
        {"name": "{{ spec.device | upper }}_POWER", "type": "bit",
         "comment": "power bit: module self-runs while bit0 = 1 (set once by starter)"},
        {"name": "{{ spec.device | upper }}_RUN_UNTIL", "type": "u64",
         "comment": "configured stop count: self-run bound (set once by starter)"}
    ],
{%- endif %}

    # --- registered outputs (the device's sole writes). -----------------------
{%- if spec.dff_nodes %}
    "dff_nodes": [
{%- for node in spec.dff_nodes %}
        {"name": "{{ node.name }}", "type": "{{ node.type }}",
         "comment": "{{ node.comment | replace('"', '\\"') }}"},
{%- endfor %}
    ],
{%- else %}
    "dff_nodes": [
        {"name": "{{ spec.device | upper }}_STATE", "type": "u64",
         "comment": "module state register"}
    ],
{%- endif %}

{%- if spec.tables %}
    # --- array registers (price-indexed tables, ring buffers, etc). ----------
    "tables": [
{%- for table in spec.tables %}
        {
            "name": "{{ table.name }}",
            "index_spec": "{{ table.index_spec }}",
            "type": "{{ table.type }}",
            "kind": "{{ table.kind | default('array') }}",
{%- if table.depth %}
            "depth": {{ table.depth }},
{%- endif %}
            "comment": "{{ table.comment | replace('"', '\\"') }}"
        },
{%- endfor %}
    ],
{%- endif %}

{%- if spec.relay_nodes %}
    # --- relay / output lanes for downstream consumers. ---
    "relay_nodes": [
{%- for node in spec.relay_nodes %}
        {
            "name": "{{ node.name }}",
            "type": "{{ node.type }}",
{%- if node.index_range %}
            "index_range": "{{ node.index_range }}",
{%- endif %}
            "comment": "{{ node.comment | replace('"', '\\"') }}"
        },
{%- endfor %}
    ],
{%- endif %}

{%- if spec.wire_inputs %}
    # --- external bus/wire inputs read by this device. ---
    "wire_inputs": [
{%- for inp in spec.wire_inputs %}
        "{{ inp }}",
{%- endfor %}
    ],
{%- endif %}

{%- if spec.comb_nodes %}
    # --- combinational logic (derived registers, computed values). -----------
    "comb_nodes": [
{%- for node in spec.comb_nodes %}
        {
            "name": "{{ node.name }}",
            "type": "{{ node.type }}",
{%- if node.cell %}
            "cell": "{{ node.cell }}",
{%- endif %}
            "comment": "{{ node.comment | replace('"', '\\"') }}"
        },
{%- endfor %}
    ],
{%- endif %}

{%- if spec.counters %}
    # --- event/diagnostic counters. ---
    "counters": [
{%- for ctr in spec.counters %}
        {
            "name": "{{ ctr.name }}",
            "type": "{{ ctr.type }}",
            "comment": "{{ ctr.comment | replace('"', '\\"') }}"
        },
{%- endfor %}
    ],
{%- endif %}

{%- if spec.power_control.power_bit %}
    # --- power / clock control. ---
    "power": "{{ spec.power_control.power_bit }}",
{%- if spec.power_control.run_bound %}
    "run": {
        "power": "{{ spec.power_control.power_bit }}",
        "count": "{{ spec.device | upper }}_TICKS",
        "limit": "{{ spec.device | upper }}_RUN_UNTIL"
    },
{%- endif %}
{%- endif %}
}


def main():
    """Emit the netlist as JSON to stdout."""
    import sys
    json.dump(NET, sys.stdout, indent=2)
    sys.stdout.write("\n")


if __name__ == "__main__":
    main()
