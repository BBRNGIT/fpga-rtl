#!/bin/bash
# commit-msg hook for fpga-rtl project
#
# Enforces the No-AI-Attribution policy (FOUNDER_VISION.md §11,
# .claude/skills/no-ai-attribution.md): commits carry the user's name only.
# Blocks ANY Co-Authored-By trailer and any AI tool attribution in the COMMIT
# MESSAGE. This runs as a commit-msg hook because that is the ONLY hook git
# passes the message file to ($1) — a pre-commit hook cannot see the message.
#
# Scope: the commit MESSAGE only. The "GENERATED by gennet.py" marker inside
# *_gen.h headers is build provenance, not attribution, and is not checked here.

set -e

msg_file="$1"
[ -f "$msg_file" ] || exit 0   # no message file => nothing to check

# Strip comment lines (git's commentary) before scanning.
commit_msg=$(grep -v '^#' "$msg_file" 2>/dev/null || cat "$msg_file")

if echo "$commit_msg" | grep -Eqi 'co-authored-by:|generated (with|by)|[^a-z0-9]claude[^a-z0-9]|anthropic|copilot|chatgpt|openai|gemini|[^a-z0-9]gpt-?[0-9o]'; then
    cat >&2 << 'EOF'

[FAIL] Commit message contains AI attribution.
       This project rejects AI co-authoring markers (FOUNDER_VISION.md §11).

       Violations detected (any of):
       - Co-Authored-By: <anyone> (all co-author trailers are rejected)
       - "Generated with/by ..." markers
       - AI tool names: Claude, Anthropic, Copilot, GPT, OpenAI, Gemini

       FIX:
       1. Edit the commit message (remove the offending line/trailer).
       2. Commit again. Commits carry the user's name only.

       Example:
         WRONG: "feat: adapter

         Co-Authored-By: Claude <noreply@anthropic.com>"

         RIGHT: "feat: add adapter — price feed deserialization"

EOF
    exit 1
fi

exit 0
