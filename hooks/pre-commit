#!/bin/bash
# pre-commit hook for fpga-rtl project
#
# Enforces:
# 1. No AI attribution (Co-Authored-By, GENERATED, etc.)
# 2. Vault immutability (.hft/ files are write-once)
# 3. Thin test size (≤45 lines)
# 4. Generated file compliance (gennet output byte-matches committed)

set -e

# ============================================================================
# 1. AI ATTRIBUTION — enforced by the commit-msg hook, NOT here.
# ============================================================================
# A pre-commit hook never receives the commit message (git supplies it only to
# prepare-commit-msg / commit-msg hooks), so checking attribution here was
# impossible: the old fallback scanned STAGED FILENAMES and false-failed any
# commit touching CLAUDE.md (the filename contains "claude"). The attribution
# policy (FOUNDER_VISION.md §11) now lives in hooks/commit-msg, which receives
# the real message at $1. Nothing to do in pre-commit.

# ============================================================================
# 2. CHECK FOR VAULT IMMUTABILITY (.hft/ write-once)
# ============================================================================

# List all modifications to .hft/ (already tracked files)
modified_in_vault=$(git diff --cached --name-only --diff-filter=M 2>/dev/null | grep "^\.hft/" || true)
deleted_in_vault=$(git diff --cached --name-only --diff-filter=D 2>/dev/null | grep "^\.hft/" || true)

if [ -n "$modified_in_vault" ] || [ -n "$deleted_in_vault" ]; then
    cat >&2 << EOF

[FAIL] Cannot modify or delete files in .hft/ (immutable vault).
       FOUNDER_VISION.md §8 — Write-once vault policy.

       Attempted modifications:
EOF
    if [ -n "$modified_in_vault" ]; then
        echo "$modified_in_vault" | sed 's/^/         (modified) /' >&2
    fi
    if [ -n "$deleted_in_vault" ]; then
        echo "$deleted_in_vault" | sed 's/^/         (deleted) /' >&2
    fi
    cat >&2 << 'EOF'

       SOLUTION:
       Create a new versioned path instead. Example:
         .hft/adapter/       (original, locked)
         .hft/adapter_v2/    (new version, start in staging)

       Steps:
       1. Unstage the vault changes: git reset HEAD .hft/...
       2. Discard them: git checkout .hft/...
       3. Copy component to .hft_staging/adapter_v2/
       4. Make changes in staging
       5. Run gate.sh and graduate.sh

       EMERGENCY OVERRIDE (rare, needs founder approval):
       git commit --no-verify -m "message"

EOF
    exit 1
fi

# ============================================================================
# 3. CHECK THIN TEST SIZE (≤45 lines)
# ============================================================================

# Find all test_*.c files being committed
test_files=$(git diff --cached --name-only 2>/dev/null | grep "test_.*\.c$" || true)

for test_file in $test_files; do
    if [ -f "$test_file" ]; then
        line_count=$(wc -l < "$test_file")
        if [ "$line_count" -gt 45 ]; then
            cat >&2 << EOF

[FAIL] Test file exceeds 45 lines (thin test philosophy).
       FOUNDER_VISION.md §9, CLAUDE.md — Testing Philosophy.

       File: $test_file
       Lines: $line_count (max: 45)

       REASON:
       Tests must be THIN: power-on + display only.
       No stepping, injection, replay, or orchestration.
       Prepped data loads at startup; device runs autonomously.

       SOLUTION:
       1. Remove testbench logic (stepping, replay, checks)
       2. Keep only: init, loop, display
       3. Re-stage and commit

       Example (correct, <45 lines):
         int main() {
           word_t *r = malloc_backplane();
           for (int i = 0; i < 1000; i++) {
             adapter_tick(r);
           }
           printf("PRICE: %lx\n", r[ADAPTER_PRICE]);
           return 0;
         }

EOF
            exit 1
        fi
    fi
done

# ============================================================================
# 4. CHECK GENERATED FILE COMPLIANCE (optional, warning only)
# ============================================================================

# For each *_gen.h being committed, verify it byte-matches gennet output
gen_files=$(git diff --cached --name-only 2>/dev/null | grep "_gen\.h$" || true)

for gen_file in $gen_files; do
    if [ -f "$gen_file" ]; then
        comp_dir=$(dirname "$gen_file")

        # Check if gennet.py exists
        if [ -f "$comp_dir/gennet.py" ]; then
            module=$(basename "$gen_file" _gen.h)
            netlist="$comp_dir/$module.net.json"

            if [ -f "$netlist" ]; then
                # Try to regenerate (ignore errors, this is optional check)
                regenerated=$(cd "$comp_dir" && python3 gennet.py "$module.net.json" 2>/dev/null || echo "SKIP")
                if [ "$regenerated" != "SKIP" ]; then
                    committed=$(cat "$gen_file" 2>/dev/null || echo "")
                    if [ "$regenerated" != "$committed" ] && [ -n "$regenerated" ]; then
                        cat >&2 << EOF

[WARN] Generated file may not match netlist.
       File: $gen_file
       Netlist: $netlist

       The committed $gen_file does not byte-match running:
         python3 gennet.py $module.net.json

       To fix (optional):
         cd $comp_dir
         python3 gennet.py $module.net.json > $module.net.json
         git add $module.net.json
         git commit

EOF
                        # This is a warning, not a failure (proceed with commit)
                    fi
                fi
            fi
        fi
    fi
done

# ============================================================================
# 5. PROTECTED ENFORCEMENT LAYER (the judges may not be edited by the judged)
# ============================================================================
# Root cause of the rejected phase-2 work: one commit created violating
# components AND edited the gate/contracts to exempt them. The enforcement
# layer therefore gets the same discipline as the vault: modifying or deleting
# any enforcement file requires the founder-granted override
# HFT_ALLOW_ENFORCEMENT_CHANGE=1. Additions of NEW check scripts are allowed
# (they can only add scrutiny); edits/deletions of existing enforcers are not.

ENFORCEMENT_PATHS='^\.hft_staging/gate\.sh$|^\.hft_staging/graduate\.sh$|^\.hft_staging/checks/|^\.hft_staging/module_contracts\.yaml$|^\.hft_staging/factory_toolchain\.yaml$|^\.hft_staging/enforcement_registry\.yaml$|^\.hft_staging/cells/cells\.h$|^hooks/|^install_hooks\.sh$'

enforcement_changed=$(git diff --cached --name-only --diff-filter=MD 2>/dev/null | grep -E "$ENFORCEMENT_PATHS" || true)

if [ -n "$enforcement_changed" ] && [ "$HFT_ALLOW_ENFORCEMENT_CHANGE" != "1" ]; then
    cat >&2 << EOF

[FAIL] Protected ENFORCEMENT files modified without the founder override.
       The judges may not be edited in the same stroke as the judged
       (this is how the rejected phase-2 self-exemption happened).

       Files:
$(echo "$enforcement_changed" | sed 's/^/         /')

       If this enforcement change is founder-sanctioned:
         HFT_ALLOW_ENFORCEMENT_CHANGE=1 git commit ...
EOF
    exit 1
fi

if [ -n "$enforcement_changed" ]; then
    echo "  [enforcement] HFT_ALLOW_ENFORCEMENT_CHANGE=1 — override active for this commit" >&2
fi

# ============================================================================
# GATE-FORCING (C1): every staged component must PASS its gate to commit.
# ============================================================================
# Correctness stops depending on anyone remembering to run gate.sh: the commit
# is BLOCKED unless every component with staged changes passes its full gate
# (validate + -Werror build + 2b-2k checks). Escape ONLY via the founder-granted
# HFT_GATE_OVERRIDE=1, which is LOGGED (visible WIP, never casual).
ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo .)
changed_components=$(git diff --cached --name-only 2>/dev/null \
    | grep -E '^\.hft_staging/[^/]+/' \
    | sed -E 's#^(\.hft_staging/[^/]+)/.*#\1#' | sort -u)

gate_failed=""
for comp in $changed_components; do
    [ -f "$ROOT/$comp/Makefile" ] || continue          # only real components
    ls "$ROOT/$comp"/*.net.json >/dev/null 2>&1 || continue
    if ! ( "$ROOT/.hft_staging/gate.sh" "$ROOT/$comp" >/tmp/gate_$$.log 2>&1 ); then
        gate_failed="$gate_failed $comp"
        echo "  [gate] FAIL: $comp" >&2
        grep -E '\[FAIL\]|FAIL|error' /tmp/gate_$$.log 2>/dev/null | head -3 | sed 's/^/        /' >&2
    fi
done
rm -f /tmp/gate_$$.log

if [ -n "$gate_failed" ]; then
    if [ "$HFT_GATE_OVERRIDE" = "1" ]; then
        echo "$(date '+%Y-%m-%d %H:%M:%S') OVERRIDE gate-fail:$gate_failed user=$(git config user.name)" \
            >> "$ROOT/.hft_staging/.gate_overrides.log"
        echo "  [gate] HFT_GATE_OVERRIDE=1 — committing ungated work (LOGGED to .gate_overrides.log):$gate_failed" >&2
    else
        cat >&2 << EOF

[FAIL] Component(s) failed the gate — commit BLOCKED:$gate_failed
       A component must PASS .hft_staging/gate.sh to be committed.
       Run it to see the failure:  .hft_staging/gate.sh .hft_staging/<component>
       If this is sanctioned work-in-progress (logged):
         HFT_GATE_OVERRIDE=1 git commit ...
EOF
        exit 1
    fi
fi

# ============================================================================
# V3 ENFORCEMENT LOCK (judges != judged) — sign-off suite files are protected.
# Editing a gate/registry/conductor requires FOUNDER_OVERRIDE=1, so a commit
# cannot weaken the gate in the same stroke that needs gating.
# ============================================================================
V3_ENFORCE='^v3_staging/tools/(erc|lvs|drc|integrity|toolgov|checks_lib)\.py$|^v3_staging/tools/gate_device\.sh$|^v3_staging/tools/enforcement_registry\.yaml$|^v3_staging/tools/hooks/preguard\.py$'
v3_enf_changed=$(git diff --cached --name-only --diff-filter=MD 2>/dev/null | grep -E "$V3_ENFORCE" || true)
if [ -n "$v3_enf_changed" ] && [ "$FOUNDER_OVERRIDE" != "1" ]; then
    cat >&2 << EOF

[FAIL] Protected v3 sign-off enforcement files modified without FOUNDER_OVERRIDE=1:
$(echo "$v3_enf_changed" | sed 's/^/         /')
       The judges may not be edited in the same stroke as the judged.
       If founder-sanctioned:  FOUNDER_OVERRIDE=1 git commit ...
EOF
    exit 1
fi

# ============================================================================
# V3 DEVICE SIGN-OFF (gate_device.sh) — staged tool/device changes must sign off.
# FAIL-CLOSED: if the conductor is missing, the commit is blocked.
# ============================================================================
v3_changed=$(git diff --cached --name-only 2>/dev/null | grep -E '^v3_staging/(tools|device)/' || true)
if [ -n "$v3_changed" ]; then
    GATE="$ROOT/v3_staging/tools/gate_device.sh"
    if [ ! -f "$GATE" ]; then
        echo "[FAIL] v3 sign-off conductor missing: v3_staging/tools/gate_device.sh (fail-closed)" >&2
        exit 1
    fi
    if ! ( sh "$GATE" >/tmp/v3gate_$$.log 2>&1 ); then
        echo "[FAIL] v3 device sign-off FAILED — commit BLOCKED:" >&2
        grep -E 'FAIL|RED' /tmp/v3gate_$$.log 2>/dev/null | head -5 | sed 's/^/        /' >&2
        rm -f /tmp/v3gate_$$.log
        if [ "$FOUNDER_OVERRIDE" = "1" ]; then
            echo "  [v3gate] FOUNDER_OVERRIDE=1 — committing despite red sign-off (logged WIP)" >&2
        else
            echo "       Run it:  sh v3_staging/tools/gate_device.sh" >&2
            exit 1
        fi
    fi
    rm -f /tmp/v3gate_$$.log
fi

# ============================================================================
# ALL CHECKS PASSED
# ============================================================================

exit 0
