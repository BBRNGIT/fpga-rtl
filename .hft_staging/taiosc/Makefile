# taisoc — TAI oscillator-reference clock. Real build, owned in this tree.
# NO poc/ reference. Flow: emitter --> netlist --validate--> (gate) --gennet-->
# device C --cc--> thin test. The netlist validator is the project gate
# (single-writer/no-overlap/no-floating).

CC      = cc
CFLAGS  = -std=c11 -Wall -Wextra -Werror -O2
PY      = python3

EMIT    = gen_taisoc_net.py
NET     = taisoc.net.json
GEN     = taisoc_gen.h

.PHONY: all emit validate gen test probe clean

all: test

# --- emitter: (re)write the netlist from the python emitter ------------------
emit: $(EMIT)
	$(PY) $(EMIT)

# --- project gate: the netlist validator ------------------------------------
validate: $(NET)
	$(PY) validate.py $(NET)

# --- generate the device C from the netlist (after the gate passes) ----------
gen: validate
	$(PY) gennet.py $(NET) > $(GEN)

# --- thin test: builds device + display + starter ---------------------------
test: gen
	$(CC) $(CFLAGS) -o test_synth test_synth.c taisoc.c display.c
	@echo "--- running taisoc thin test ---"
	./test_synth

# --- external diagnostic: the register snapshot (NOT the device, NOT a test) -
probe: test
	@echo "--- probe: taisoc register snapshot ---"
	./test_synth

clean:
	rm -f $(GEN) test_synth probe

# the netlist is generated by the emitter; regenerate it explicitly with `make emit`.
$(NET): $(EMIT)
	$(PY) $(EMIT)
