# dom device — the order book. Real build, owned in this tree.
# Flow: emitter --> netlist --validate--> (gate) --gennet--> device C --cc--> thin test.
# The netlist validator is the project gate (single-writer/no-overlap/no-floating/
# module-barrier/consume-gate).

CC      = cc
CFLAGS  = -std=c11 -Wall -Wextra -Werror -O2
PY      = python3

EMIT    = gen_dom_net.py
NET     = dom.net.json
GEN     = dom_gen.h

# --- the fifo_rx window DOM SAMPLES (the head slot + RD_FIRE/EMPTY flags). There
# is NO hand-maintained copy of the FIFO map: regenerate fifo_rx's CANONICAL header
# from its single source via fifo_rx's own gennet. The fifo_rx seam in turn pulls
# the nic + wire + tai_cdc canonical headers (the fifo_rx gennet #includes nic_gen.h,
# whose gennet #includes wire/tai_cdc), so we regenerate those siblings here too.
# These sibling headers are gitignored (regenerated, never committed copies); only
# THIS device's dom_gen.h is committed. -----------------------------------------------
FIFO_DIR    = ../fifo_rx
FIFO_NET    = $(FIFO_DIR)/fifo_rx.net.json
FIFO_GEN    = fifo_rx_gen.h

NIC_DIR     = ../nic
NIC_NET     = $(NIC_DIR)/nic.net.json
NIC_GEN     = nic_gen.h

WIRE_DIR    = ../wire
WIRE_NET    = $(WIRE_DIR)/wire.net.json
WIRE_GEN    = wire_gen.h

TAI_CDC_DIR = ../tai_cdc
TAI_CDC_NET = $(TAI_CDC_DIR)/tai_cdc.net.json
TAI_CDC_GEN = tai_cdc_gen.h

.PHONY: all emit validate gen test probe clean

all: test

# --- emit the netlist from the emitter (the python deliverable) ---------------
emit: $(EMIT)
	$(PY) $(EMIT)

$(NET): $(EMIT)
	$(PY) $(EMIT)

# --- project gate: the netlist validator --------------------------------------
validate: $(NET)
	$(PY) validate.py $(NET)

# --- regenerate the sibling seam headers from their single sources ------------
$(WIRE_GEN): $(WIRE_NET) $(WIRE_DIR)/gennet.py
	$(PY) $(WIRE_DIR)/gennet.py $(WIRE_NET) > $(WIRE_GEN)

$(TAI_CDC_GEN): $(TAI_CDC_NET) $(TAI_CDC_DIR)/gennet.py
	$(PY) $(TAI_CDC_DIR)/gennet.py $(TAI_CDC_NET) > $(TAI_CDC_GEN)

# the nic seam header #includes wire_gen.h + tai_cdc_gen.h, so they must exist first.
$(NIC_GEN): $(NIC_NET) $(NIC_DIR)/gennet.py $(WIRE_GEN) $(TAI_CDC_GEN)
	$(PY) $(NIC_DIR)/gennet.py $(NIC_NET) > $(NIC_GEN)

# the fifo_rx head header #includes nic_gen.h, so it must exist first.
$(FIFO_GEN): $(FIFO_NET) $(FIFO_DIR)/gennet.py $(NIC_GEN)
	$(PY) $(FIFO_DIR)/gennet.py $(FIFO_NET) > $(FIFO_GEN)

# --- generate THIS device's C from its netlist (after the gate passes). This is
# the COMMITTED artifact (build-sequence law: *_gen.h is committed + graduated). ---
gen: validate $(FIFO_GEN)
	$(PY) gennet.py $(NET) > $(GEN)

# --- thin test: builds device + starter + display -----------------------------
test: gen
	$(CC) $(CFLAGS) -o test_synth test_synth.c dom.c display.c
	@echo "--- running dom thin test ---"
	./test_synth

probe: test
	@echo "--- probe: dom register snapshot ---"
	./test_synth

# clean removes the SIBLING regenerated headers + compiled artifacts. It does NOT
# remove dom_gen.h: that is this device's committed deliverable, regenerated by
# `make gen` but tracked in git (build-sequence law). -------------------------------
clean:
	rm -f $(FIFO_GEN) $(NIC_GEN) $(WIRE_GEN) $(TAI_CDC_GEN) test_synth probe
