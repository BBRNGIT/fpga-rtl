# fifo_rx device — the MAC->internal async CDC FIFO. Real build, owned in this tree.
# Flow: emitter --> netlist --validate--> (gate) --gennet--> device C --cc--> thin test.
# The netlist validator is the project gate (single-writer/no-overlap/no-floating/cdc).

CC      = cc
CFLAGS  = -std=c11 -Wall -Wextra -Werror -O2
PY      = python3

EMIT    = gen_fifo_rx_net.py
NET     = fifo_rx.net.json
GEN     = fifo_rx_gen.h

# --- the nic seam this FIFO SAMPLES. fifo_rx reads the nic's SEAM_* lanes. There
# is NO hand-maintained copy of the nic map: regenerate the nic's CANONICAL header
# from its single source via the nic's own gennet. The nic seam in turn pulls the
# wire + tai_cdc canonical headers (the nic gennet #includes them), so we regenerate
# those siblings here too. These three sibling headers are gitignored (regenerated,
# never committed copies); only THIS device's fifo_rx_gen.h is committed. -----------
NIC_DIR     = ../nic
NIC_NET     = $(NIC_DIR)/nic.net.json
NIC_GEN     = nic_gen.h

WIRE_DIR    = ../wire
WIRE_NET    = $(WIRE_DIR)/wire.net.json
WIRE_GEN    = wire_gen.h

TAI_CDC_DIR = ../tai_cdc
TAI_CDC_NET = $(TAI_CDC_DIR)/tai_cdc.net.json
TAI_CDC_GEN = tai_cdc_gen.h

.PHONY: all emit validate gen test probe clean

all: test

# --- emit the netlist from the emitter (the python deliverable) ---------------
emit: $(EMIT)
	$(PY) $(EMIT)

$(NET): $(EMIT)
	$(PY) $(EMIT)

# --- project gate: the netlist validator --------------------------------------
validate: $(NET)
	$(PY) validate.py $(NET)

# --- regenerate the sibling seam headers from their single sources ------------
$(WIRE_GEN): $(WIRE_NET) $(WIRE_DIR)/gennet.py
	$(PY) $(WIRE_DIR)/gennet.py $(WIRE_NET) > $(WIRE_GEN)

$(TAI_CDC_GEN): $(TAI_CDC_NET) $(TAI_CDC_DIR)/gennet.py
	$(PY) $(TAI_CDC_DIR)/gennet.py $(TAI_CDC_NET) > $(TAI_CDC_GEN)

# the nic seam header #includes wire_gen.h + tai_cdc_gen.h, so they must exist first.
$(NIC_GEN): $(NIC_NET) $(NIC_DIR)/gennet.py $(WIRE_GEN) $(TAI_CDC_GEN)
	$(PY) $(NIC_DIR)/gennet.py $(NIC_NET) > $(NIC_GEN)

# --- generate THIS device's C from its netlist (after the gate passes). This is
# the COMMITTED artifact (build-sequence law: *_gen.h is committed + graduated). ---
gen: validate $(NIC_GEN)
	$(PY) gennet.py $(NET) > $(GEN)

# --- thin test: builds device + starter + display -----------------------------
test: gen
	$(CC) $(CFLAGS) -o test_synth test_synth.c fifo_rx.c display.c
	@echo "--- running fifo_rx thin test ---"
	./test_synth

probe: test
	@echo "--- probe: fifo_rx register snapshot ---"
	./test_synth

# clean removes the SIBLING regenerated headers + compiled artifacts. It does NOT
# remove fifo_rx_gen.h: that is this device's committed deliverable, regenerated by
# `make gen` but tracked in git (build-sequence law). -------------------------------
clean:
	rm -f $(NIC_GEN) $(WIRE_GEN) $(TAI_CDC_GEN) test_synth probe
